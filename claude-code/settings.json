{
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "model": "opus",
  "hooks": {
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-event create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-event remove"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-posttooluse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-precompact"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/context-bar.sh"
  },
  "enabledPlugins": {
    "sentrux@sentrux-marketplace": true,
    "dev-workflow@unimatrix-forge": true,
    "superpowers@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "sentrux-marketplace": {
      "source": {
        "source": "github",
        "repo": "sentrux/sentrux"
      }
    },
    "unimatrix-forge": {
      "source": {
        "source": "directory",
        "path": "/Users/partiwari/code/ai-toolkit"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "pmll-memory-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "pmll-memory-mcp"
      ]
    },
    "linear": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ]
    }
  }
}
